# Flask API Configuration
# Copy this file to .env and customize as needed

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# CORS Configuration
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# Request Size Limit (in bytes)
# Default: 16MB (16 * 1024 * 1024)
MAX_CONTENT_LENGTH=16777216

# Production Settings (when using Gunicorn)
# Number of worker processes
WORKERS=4

# Worker class (sync, gevent, eventlet)
WORKER_CLASS=sync

# Request timeout (seconds)
TIMEOUT=30

# SAP Translation Hub Configuration (for label translation)
TRANSLATION_HUB_CLIENT_ID=your-translation-hub-client-id
TRANSLATION_HUB_CLIENT_SECRET=your-translation-hub-client-secret
TRANSLATION_HUB_AUTH_URL=https://your-subaccount.authentication.eu11.hana.ondemand.com
TRANSLATION_HUB_API_URL=https://document-translation.api.eu11.translationhub.cloud.sap
